# Pinecone API Key
# 从 Pinecone 控制台获取: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here

# 向量嵌入 API Key
# 从你的向量服务提供商获取
EMBEDDING_API_KEY=your_embedding_api_key_here

# 向量嵌入 API 地址
# 示例: https://api.vectorengine.ai/v1
EMBEDDING_BASE_URL=https://api.vectorengine.ai/v1

# 向量嵌入模型
# 示例: text-embedding-3-large, text-embedding-3-small, etc.
EMBEDDING_MODEL=text-embedding-3-large

# Pinecone 索引名称
INDEX_NAME=your index name

# Pinecone 命名空间（可选）
# 用于隔离不同类型的数据
# 如果不需要命名空间隔离，留空即可
NAMESPACE=design-standard
